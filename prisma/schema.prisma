generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth standard models - do not modify field names
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  repos         Repo[]
  createdAt     DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Repo {
  id        String        @id @default(cuid())
  githubId  Int           @unique
  name      String
  fullName  String
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  events    GithubEvent[]
  metrics   DailyMetric[]
  createdAt DateTime      @default(now())
}

model GithubEvent {
  id         String   @id @default(cuid())
  repoId     String
  repo       Repo     @relation(fields: [repoId], references: [id])
  type       String
  payload    Json
  actor      String
  occurredAt DateTime
  createdAt  DateTime @default(now())

  @@index([repoId, type, occurredAt])
}

model DailyMetric {
  id                  String   @id @default(cuid())
  repoId              String
  repo                Repo     @relation(fields: [repoId], references: [id])
  date                DateTime @db.Date
  prMerged            Int      @default(0)
  prOpened            Int      @default(0)
  avgCycleTimeMinutes Int?
  deployFrequency     Float?
  commits             Int      @default(0)
  createdAt           DateTime @default(now())

  @@unique([repoId, date])
  @@index([repoId, date])
}
